<!-- Companion Level Modal -->
<div id="companionModalOverlay" class="modal-overlay companion-modal-overlay">
    <div class="modal-dialog companion-modal-dialog">
        <div class="modal-header companion-sheet-header">
            <h3>✨ Уровень компаньона</h3>
            <button type="button" class="modal-close-btn" id="companionCloseBtn">&times;</button>
        </div>
        <div id="companionContent" class="modal-body companion-modal-body">
            <!-- Содержимое будет загружено здесь -->
            <div class="companion-loading">
                <div class="spinner">⏳</div>
                <p>Загрузка...</p>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" id="companionCloseBtn2">Закрыть</button>
        </div>
    </div>
</div>

<script>
    /**
     * Companion Modal Management
     */
    class CompanionModal {
        constructor() {
            this.modal = document.getElementById('companionModalOverlay');
            this.content = document.getElementById('companionContent');
            this.closeBtn = document.getElementById('companionCloseBtn');
            this.closeBtn2 = document.getElementById('companionCloseBtn2');

            this.init();
        }

        init() {
            if (this.closeBtn) {
                this.closeBtn.addEventListener('click', () => this.close());
            }
            if (this.closeBtn2) {
                this.closeBtn2.addEventListener('click', () => this.close());
            }

            if (this.modal) {
                this.modal.addEventListener('click', (e) => {
                    if (e.target === this.modal) {
                        this.close();
                    }
                });
            }

            // Обработчик для кнопки открытия модали компаньена
            document.addEventListener('click', (e) => {
                if (e.target.classList.contains('btn-companion-info')) {
                    e.preventDefault();
                    this.open();
                }
            });
        }

        async open() {
            try {
                const response = await fetch('/api/companion/level-info');
                const data = await response.json();

                this.renderCompanionInfo(data);
                if (this.modal) {
                    this.modal.classList.add('active');
                }
            } catch (error) {
                console.error('Error loading companion info:', error);
                this.content.innerHTML = '<p style="color: red;">Ошибка при загрузке информации</p>';
                if (this.modal) {
                    this.modal.classList.add('active');
                }
            }
        }

        close() {
            if (this.modal) {
                this.modal.classList.remove('active');
            }
        }

        renderCompanionInfo(data) {
            const levelVisual = this.getLevelVisual(data.currentLevel);
            const levelCap = this.getLevelCap(data.currentLevel, !!data.maxLevel);
            const daysDone = Math.max(0, levelCap.range - data.daysToNextLevel);

            const html = `
                <div class="companion-content companion-level-surface ${levelVisual.className}">
                    <div class="companion-header companion-level-head">
                        <div class="companion-level-badge companion-level-pill">
                            <span class="level-emoji">${levelVisual.emoji}</span>
                            <div>
                                <div class="level-number">Уровень ${data.currentLevel}${data.currentLevel >= 5 ? '+' : ''}</div>
                                <div class="companion-level-state">${levelVisual.state}</div>
                            </div>
                        </div>
                        <div class="companion-name">${levelVisual.name}</div>
                    </div>

                    <div class="companion-stats companion-stats-compact">
                        <div class="stat-item">
                            <span class="stat-label">📅 В системе</span>
                            <span class="stat-value">${data.daysInSystem}</span>
                        </div>

                        <div class="stat-item">
                            <span class="stat-label">⏭ До next</span>
                            <span class="stat-value">${data.maxLevel ? 'MAX' : data.daysToNextLevel + ' дн'}</span>
                        </div>
                    </div>

                    <div class="companion-progress">
                        <div class="progress-label">
                            <span>Прогресс уровня · ${daysDone}/${levelCap.range} дней</span>
                            <span>${data.progressPercent}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${data.progressPercent}%"></div>
                        </div>
                    </div>

                    <div class="companion-mini-achievements">
                        <span>🏁</span>
                        <span>🎯</span>
                        <span>💜</span>
                        <span>🔥</span>
                    </div>

                    ${data.maxLevel ? `
                        <div class="companion-message">
                            🌟 Мастер‑уровень достигнут. Вы в топовой форме.
                        </div>
                    ` : ''}

                    <div class="companion-info-text">
                        <p>
                            Чем стабильнее ваша активность, тем ярче визуальный уровень компаньона: от нейтрального к «master».
                        </p>
                    </div>
                </div>
            `;

            this.content.innerHTML = html;
        }

        getLevelCap(level, maxLevel) {
            if (maxLevel || level >= 5) return { range: 30 };
            if (level === 1) return { range: 3 };
            if (level === 2) return { range: 7 };
            if (level === 3) return { range: 20 };
            return { range: 30 };
        }

        getLevelVisual(level) {
            if (level <= 1) return { emoji: '⚪', name: 'Base', state: 'Нейтральный старт', className: 'companion-level-1' };
            if (level === 2) return { emoji: '🟣', name: 'Soft Glow', state: 'Мягкое свечение', className: 'companion-level-2' };
            if (level === 3) return { emoji: '🔵', name: 'Active', state: 'Яркий режим', className: 'companion-level-3' };
            if (level === 4) return { emoji: '🟪', name: 'Aura', state: 'Глубокая аура', className: 'companion-level-4' };
            return { emoji: '🌈', name: 'Master', state: 'TikTok‑уровень', className: 'companion-level-5' };
        }
    }

    // Инициализировать при загрузке
    document.addEventListener('DOMContentLoaded', () => {
        new CompanionModal();
    });
</script>
