<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sofia.Web</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/spacing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navigation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/companion-redesign.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sofia.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/system.css" asp-append-version="true" />
</head>
<body>
    @{ var currentPath = Context.Request.Path.ToString().ToLowerInvariant(); }
    <header class="topbar">
        <div class="container-fluid topbar-inner">
            <!-- Логотип "НС" / Главная -->
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index" title="НС - Наша София">
                <img src="~/img/logo/logo-ns.svg" alt="НС логотип" class="logo-icon" />
            </a>
            
            <!-- Основное меню навигации -->
            <nav class="main-nav">
                @{
                    var isAuthenticated = Context.User?.Identity?.IsAuthenticated ?? false;
                    var userRole = Context.Session.GetString("UserRole") ?? "";
                }

                @if (isAuthenticated)
                {
                    <!-- Для авторизованных пользователей -->
                    <a asp-area="" asp-controller="Notes" asp-action="Index" class="@(currentPath.StartsWith("/notes") ? "active" : "")">Заметки</a>
                    <a asp-area="" asp-controller="Calendar" asp-action="Index" class="@(currentPath.StartsWith("/calendar") ? "active" : "")">Календарь</a>
                    <a asp-area="" asp-controller="Goals" asp-action="Index" class="@(currentPath.StartsWith("/goals") ? "active" : "")">Цели</a>
                    <a asp-area="" asp-controller="Stats" asp-action="Index" class="@(currentPath.StartsWith("/stats") ? "active" : "")">Статистика</a>
                    <a asp-area="" asp-controller="Practices" asp-action="Index" class="@(currentPath.StartsWith("/practices") ? "active" : "")">Практики</a>
                    <a asp-area="" asp-controller="Psychologist" asp-action="Index" class="@(currentPath.StartsWith("/psychologist") ? "active" : "")">Психолог</a>
                    <a asp-area="" asp-controller="Tests" asp-action="Index" class="@(currentPath.StartsWith("/tests") ? "active" : "")">Тесты</a>
                    <a asp-area="" asp-controller="ChatPage" asp-action="Index" class="@(currentPath.StartsWith("/chat") ? "active" : "")">Чат</a>
                    <a asp-area="" asp-controller="ForumPage" asp-action="Index" class="@(currentPath.StartsWith("/forum") ? "active" : "")">Форум</a>
                    
                    @if (string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <a asp-area="" asp-controller="Admin" asp-action="Index" class="@(currentPath.StartsWith("/admin") ? "active" : "") admin-link">Админ‑панель</a>
                    }
                }
                else
                {
                    <!-- Для гостей (приватные разделы с редиректом на логин) -->
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Notes/Index" })">Заметки</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Calendar/Index" })">Календарь</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Goals/Index" })">Цели</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Stats/Index" })">Статистика</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Practices/Index" })">Практики</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Psychologist/Index" })">Психолог</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Tests/Index" })">Тесты</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Chat/Index" })">Чат</a>
                    <a href="@Url.Action("Login", "Auth", new { returnUrl = "/Forum/Index" })">Форум</a>
                }
            </nav>
            
            <!-- Правая часть: вход/регистрация или профиль -->
            <div class="profile-block">
                @if (isAuthenticated)
                {
                    <!-- Для авторизованных пользователей -->
                    <button type="button" class="profile-trigger" id="profileTrigger">
                        <span class="profile-avatar">@((Context.Session.GetString("Username") ?? "П").FirstOrDefault().ToString().ToUpper())</span>
                        <span class="profile-name">@(Context.Session.GetString("Username") ?? "Пользователь")</span>
                    </button>
                    <div class="profile-menu" id="profileMenu">
                        <a asp-area="" asp-controller="Settings" asp-action="Profile" class="profile-item">Профиль</a>
                        <a asp-area="" asp-controller="Settings" asp-action="Index" class="profile-item">Настройки</a>
                        @if (string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase))
                        {
                            <a asp-area="" asp-controller="Admin" asp-action="Index" class="profile-item">Админ‑панель</a>
                        }
                        <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="profile-logout">
                            <button type="submit" class="profile-item">Выход</button>
                        </form>
                    </div>
                }
                else
                {
                    <!-- Для гостей -->
                    <a asp-area="" asp-controller="Auth" asp-action="Login" class="nav-link btn-login">Войти</a>
                    <a asp-area="" asp-controller="Auth" asp-action="Register" class="nav-link btn-register">Регистрация</a>
                }
            </div>
        </div>
    </header>
    <div class="container main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Sofia.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Goal Action Modals -->
    @await Html.PartialAsync("_GoalActionModals")

    <!-- Companion Modal -->
    @await Html.PartialAsync("_CompanionModal")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/goal-action-modal.js" asp-append-version="true"></script>
    <script>
        window.currentUserRole = '@(Context.Session.GetString("UserRole") ?? "")';
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const trigger = document.getElementById('profileTrigger');
            const menu = document.getElementById('profileMenu');
            if (!trigger || !menu) return;

            trigger.addEventListener('click', function (event) {
                event.stopPropagation();
                menu.parentElement.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!menu.contains(event.target) && !trigger.contains(event.target)) {
                    menu.parentElement.classList.remove('open');
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
