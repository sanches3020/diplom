<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Нить сознания</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="manifest" href="~/manifest.json" />
    <link rel="icon" href="~/favicon/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="~/favicon/favicon.ico" type="image/x-icon" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sofia.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header class="app-bar">
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo/logo-light.svg" alt="Нить сознания" height="32" class="d-inline-block align-top">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Открыть меню">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 text-center">
                        <li class="nav-item"><a class="nav-link" href="/home">Главная</a></li>
                        <li class="nav-item"><a class="nav-link" href="/notes">Заметки</a></li>
                        <li class="nav-item"><a class="nav-link" href="/calendar">Календарь</a></li>
                        <li class="nav-item"><a class="nav-link" href="/goals">Цели</a></li>
                        <li class="nav-item"><a class="nav-link" href="/stats">Статистика</a></li>
                        <li class="nav-item"><a class="nav-link" href="/practices">Практики</a></li>
                        <li class="nav-item"><a class="nav-link" href="/psychologist">Психолог</a></li>
                        <li class="nav-item"><a class="nav-link" href="/tests">Тесты</a></li>
                        <li class="nav-item"><a class="nav-link" href="/chat">Чат</a></li>
                        <li class="nav-item"><a class="nav-link" href="/forum">Форум</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (Context.Session.GetString("UserId") != null)
                        {
                            var userRole = Context.Session.GetString("UserRole")?.ToLowerInvariant();
                            <div class="dropdown profile-menu">
                                <button class="btn profile-button dropdown-toggle" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="avatar-icon">@((Context.Session.GetString("Username") ?? "S")[0])</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                    <li><a class="dropdown-item" href="/settings/profile">Профиль</a></li>
                                    <li><a class="dropdown-item" href="/settings">Настройки</a></li>
                                    @if (userRole == "admin" || userRole == "administrator")
                                    {
                                        <li><a class="dropdown-item" href="/admin">Админ‑панель</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item">Выйти</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/auth/login" class="btn btn-outline-primary btn-sm">Войти</a>
                            <a href="/auth/register" class="btn btn-primary btn-sm">Регистрация</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="page-shell">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Нить сознания - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Expose current user role to client scripts
        window.currentUserRole = '@(Context.Session.GetString("UserRole") ?? "")';
    </script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
