<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sofia.Web</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Sofia.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/system.css" asp-append-version="true" />
</head>
<body>
    @{ var currentPath = Context.Request.Path.ToString().ToLowerInvariant(); }
    <header class="topbar">
        <div class="container-fluid topbar-inner">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                Sofia
            </a>
            <nav class="main-nav">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="@(currentPath.StartsWith("/home") || currentPath == "/" ? "active" : "")">Главная</a>
                <a asp-area="" asp-controller="Chat" asp-action="Index" class="@(currentPath.StartsWith("/chat") ? "active" : "")">Чат</a>
                <a asp-area="" asp-controller="Forum" asp-action="Index" class="@(currentPath.StartsWith("/forum") ? "active" : "")">Форум</a>
            </nav>
            <div class="profile-block">
                <button type="button" class="profile-trigger" id="profileTrigger">
                    <span class="profile-avatar">@((Context.Session.GetString("Username") ?? "П").FirstOrDefault().ToString().ToUpper())</span>
                    <span>@(Context.Session.GetString("Username") ?? "Гость")</span>
                </button>
                <div class="profile-menu" id="profileMenu">
                    <a asp-area="" asp-controller="Settings" asp-action="Profile" class="profile-item">Профиль</a>
                    <a asp-area="" asp-controller="Settings" asp-action="Index" class="profile-item">Настройки</a>
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a asp-area="" asp-controller="Admin" asp-action="Index" class="profile-item">Админ‑панель</a>
                    }
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="profile-item">Выход</button>
                    </form>
                </div>
            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Sofia.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        window.currentUserRole = '@(Context.Session.GetString("UserRole") ?? "")';
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const trigger = document.getElementById('profileTrigger');
            const menu = document.getElementById('profileMenu');
            if (!trigger || !menu) return;

            trigger.addEventListener('click', function (event) {
                event.stopPropagation();
                menu.parentElement.classList.toggle('open');
            });

            document.addEventListener('click', function (event) {
                if (!menu.contains(event.target) && !trigger.contains(event.target)) {
                    menu.parentElement.classList.remove('open');
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
