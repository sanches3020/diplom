@model List<ApplicationUser>

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Администрирование</p>
            <h1 class="page-title">Админ‑панель</h1>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-stats">
            <div class="admin-card">
                <h3>Пользователей</h3>
                <div class="stat-value">@Model.Count</div>
                <p class="section-note">Активных аккаунтов сейчас</p>
            </div>
            <div class="admin-card">
                <h3>Новые заявки</h3>
                <div class="stat-value">18</div>
                <p class="section-note">Ожидают проверки</p>
            </div>
            <div class="admin-card">
                <h3>Ошибки</h3>
                <div class="stat-value">4</div>
                <p class="section-note">Последние 24 часа</p>
            </div>
        </div>

        <div class="admin-card">
            <div class="admin-tools">
                <input type="search" class="input-field" placeholder="Поиск пользователей" />
                <select class="select-field">
                    <option>Все роли</option>
                    <option>Администратор</option>
                    <option>Пользователь</option>
                    <option>Психолог</option>
                </select>
                <button class="btn btn-brand" type="button">Новый пользователь</button>
            </div>

            <div class="user-table-wrapper">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="user-avatar">@((u.FullName ?? u.UserName ?? "U").FirstOrDefault().ToString().ToUpper())</span>
                                        <div>
                                            <div>@(u.FullName ?? u.UserName)</div>
                                            <div class="text-muted" style="font-size:0.9rem;">@u.UserName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@u.Email</td>
                                <td>@u.Role</td>
                                <td>@(u.IsBlocked ? "Заблокирован" : "Активен")</td>
                                <td>
                                    <div class="action-chip">Действия</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
