@model List<Sofia.Web.ViewModels.Admin.AdminUserViewModel>

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Администрирование</p>
            <h1 class="page-title">Админ‑панель</h1>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-stats">
            <div class="admin-card">
                <h3>Пользователей</h3>
                <div class="stat-value">@Model.Count</div>
                <p class="section-note">Активных аккаунтов сейчас</p>
            </div>
            <div class="admin-card">
                <h3>Новые заявки</h3>
                <div class="stat-value">18</div>
                <p class="section-note">Ожидают проверки</p>
            </div>
            <div class="admin-card">
                <h3>Ошибки</h3>
                <div class="stat-value">4</div>
                <p class="section-note">Последние 24 часа</p>
            </div>
        </div>

        <div class="admin-card">
            <div class="admin-tools">
                <input type="search" class="input-field" placeholder="Поиск пользователей" />
                <select class="select-field">
                    <option>Все роли</option>
                    <option>Администратор</option>
                    <option>Пользователь</option>
                    <option>Психолог</option>
                </select>
                <button class="btn btn-brand" type="button">Новый пользователь</button>
            </div>

            <div class="user-table-wrapper">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="user-avatar">@((u.User.FullName ?? u.User.UserName ?? "U").FirstOrDefault().ToString().ToUpper())</span>
                                        <div>
                                            <div>@(u.User.FullName ?? u.User.UserName)</div>
                                            <div class="text-muted" style="font-size:0.9rem;">@u.User.UserName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@u.User.Email</td>
                                <td>@string.Join(", ", u.Roles)</td>
                                <td>@(u.User.IsBlocked ? "Заблокирован" : "Активен")</td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        @if (u.User.IsBlocked)
                                        {
                                            <form asp-action="Unblock" asp-route-id="@u.User.Id" method="post">
                                                <button type="submit" class="action-chip border-0">Разблокировать</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Block" asp-route-id="@u.User.Id" method="post">
                                                <button type="submit" class="action-chip border-0">Заблокировать</button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@u.User.Id" method="post" onsubmit="return confirm('Удалить пользователя?');">
                                            <button type="submit" class="action-chip border-0">Удалить</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
