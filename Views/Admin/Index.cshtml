@model List<ApplicationUser>

<h1>Админ‑панель</h1>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Имя</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Email</td>
                <td>@u.FullName</td>
                <td>@(u.IsBlocked ? "Заблокирован" : "Активен")</td>
                <td>
                    @if (!u.IsBlocked)
                    {
                        <form method="post" asp-action="Block" asp-route-id="@u.Id">
                            <button class="btn btn-warning">Блокировать</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-action="Unblock" asp-route-id="@u.Id">
                            <button class="btn btn-success">Разблокировать</button>
                        </form>
                    }

                    <form method="post" asp-action="Delete" asp-route-id="@u.Id">
                        <button class="btn btn-danger">Удалить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
