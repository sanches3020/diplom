@page
@model Sofia.Web.Views.Forum.IndexModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/forum.css" asp-append-version="true" />

<div class="forum-page">
    <div class="forum-hero">
        <div>
            <p class="eyebrow">Форум поддержки</p>
            <h1>Место для спокойного общения и обмена опытом</h1>
            <p>Ищи темы, делись идеями или задавай вопрос — всё организовано легко и без шума.</p>
            <div class="hero-actions">
                <a class="btn btn-primary" href="/forum/createthread">Создать тему</a>
                <a class="btn btn-outline-primary" href="/forum/category">Все категории</a>
            </div>
            <div class="forum-search">
                <input type="search" placeholder="Поиск по темам, тегам и авторам" aria-label="Поиск по форуму" />
                <button type="button" class="btn btn-primary">Найти</button>
            </div>
        </div>
        <aside class="forum-sidebar">
            <section class="category-panel">
                <h3>Категории</h3>
                <ul>
                    <li class="active">Общее</li>
                    <li>Самопомощь</li>
                    <li>Эмоции</li>
                    <li>Сон</li>
                    <li>Тревога</li>
                </ul>
            </section>
            <section class="stats-panel">
                <h3>Статистика</h3>
                <div class="stat-line"><strong>127</strong><span>тем</span></div>
                <div class="stat-line"><strong>844</strong><span>ответа</span></div>
                <div class="stat-line"><strong>28</strong><span>активных авторов</span></div>
            </section>
        </aside>
    </div>

    <main class="forum-main">
        <section class="thread-list" aria-label="Список тем форума">
            <article class="thread-card">
                <div class="meta-row">
                    <span class="tag">Эмоции</span>
                    <span>Автор: Анна</span>
                </div>
                <h2><a href="/forum/thread">Как справляться с тревогой перед сном?</a></h2>
                <p>Поделитесь простыми техниками, которые помогают успокоиться без лекарств.</p>
                <div class="thread-footer">
                    <small>24 ответа · 3 часа назад</small>
                    <div class="thread-meta">
                        <span class="tag">Анонимно</span>
                    </div>
                </div>
            </article>

            <article class="thread-card">
                <div class="meta-row">
                    <span class="tag">Самопомощь</span>
                    <span>Автор: Вячеслав</span>
                </div>
                <h2><a href="/forum/thread">Как построить полезный утренний ритуал?</a></h2>
                <p>Ищу мягкий старт дня, который не вызывает тревоги и помогает сохранять структуру.</p>
                <div class="thread-footer">
                    <small>15 ответов · вчера</small>
                    <div class="thread-meta">
                        <span class="tag">Практика</span>
                    </div>
                </div>
            </article>

            <article class="thread-card">
                <div class="meta-row">
                    <span class="tag">Сон</span>
                    <span>Автор: Мария</span>
                </div>
                <h2><a href="/forum/thread">Мягкие способы улучшить качество сна</a></h2>
                <p>Какие ежедневные привычки помогают лучше засыпать и просыпаться спокойнее?</p>
                <div class="thread-footer">
                    <small>9 ответов · 2 дня назад</small>
                    <div class="thread-meta">
                        <span class="tag">Ночью</span>
                    </div>
                </div>
            </article>
        </section>

        <aside class="forum-sidebar">
            <section class="category-panel">
                <h3>Популярные теги</h3>
                <div class="tag-grid">
                    <li class="tag">Поддержка</li>
                    <li class="tag">Тревога</li>
                    <li class="tag">Эмоции</li>
                    <li class="tag">Ритуалы</li>
                    <li class="tag">Сон</li>
                </div>
            </section>
            <section class="stats-panel">
                <h3>Рекомендация</h3>
                <p>Если вам важно спокойствие — выбирайте темы с пометкой «Анонимно» и короткими ответами.</p>
            </section>
        </aside>
    </main>
</div>
