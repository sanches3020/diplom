@page
@model Sofia.Web.Views.Forum.IndexModel
@{
    ViewData["Title"] = "Форум";
}

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Обсуждения сообщества</p>
            <h1 class="page-title">Форум</h1>
        </div>
        <a href="/Forum/CreateThread" class="btn btn-brand">Создать тему</a>
    </div>

    <div class="forum-layout">
        <section class="forum-list">
            <div class="forum-header">
                <div>
                    <p class="section-note">Топ темы</p>
                    <h2 class="section-title">Новые обсуждения</h2>
                </div>
                <div class="thread-tags">
                    <span class="tag-pill">Психология</span>
                    <span class="tag-pill">Эмоции</span>
                </div>
            </div>

            <div class="forum-cards">
                <a href="/Forum/Thread/1" class="forum-card">
                    <h3 class="forum-card-title">Как организовать ежедневный эмоциональный журнал?</h3>
                    <div class="forum-card-meta">Автор: Анастасия · 1 час назад · 32 ответа</div>
                    <div class="thread-tags">
                        <span class="tag-pill">Дневник</span>
                        <span class="tag-pill">Рутина</span>
                    </div>
                </a>

                <a href="/Forum/Thread/2" class="forum-card">
                    <h3 class="forum-card-title">Советы по спокойному утреннему ритуалу</h3>
                    <div class="forum-card-meta">Автор: Павел · 3 часа назад · 18 ответов</div>
                    <div class="thread-tags">
                        <span class="tag-pill">Утро</span>
                        <span class="tag-pill">Привычки</span>
                    </div>
                </a>

                <a href="/Forum/Thread/3" class="forum-card">
                    <h3 class="forum-card-title">Как делиться эмоциями с близкими без напряжения?</h3>
                    <div class="forum-card-meta">Автор: Мария · вчера · 24 ответа</div>
                    <div class="thread-tags">
                        <span class="tag-pill">Отношения</span>
                        <span class="tag-pill">Разговор</span>
                    </div>
                </a>
            </div>
        </section>

        <aside class="forum-thread-panel">
            <div class="thread-header">
                <p class="section-note">Навигация</p>
                <h2 class="section-title">Категории и теги</h2>
            </div>
            <div class="comments-feed">
                <div class="comment-item">
                    <div class="comment-avatar">Т</div>
                    <div class="comment-body">
                        <p class="comment-text">Тренды</p>
                        <div class="comment-meta">12 активных тем</div>
                    </div>
                </div>
                <div class="comment-item">
                    <div class="comment-avatar">П</div>
                    <div class="comment-body">
                        <p class="comment-text">Практики</p>
                        <div class="comment-meta">8 материалов</div>
                    </div>
                </div>
                <div class="comment-item">
                    <div class="comment-avatar">Л</div>
                    <div class="comment-body">
                        <p class="comment-text">Личный опыт</p>
                        <div class="comment-meta">20 историй</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>
