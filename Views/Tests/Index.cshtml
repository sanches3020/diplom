@model Sofia.Web.ViewModels.UserTest.UserTestListViewModel

@{
    ViewData["Title"] = "Тесты";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Тесты и шкалы</h2>
    <div class="d-flex gap-2 align-items-center">
        <a href="/tests/analytics" class="btn btn-outline-info btn-sm">Аналитика</a>
    </div>
</div>

<div class="row g-4 pb-5">
    @if (Model?.Tests != null && Model.Tests.Any())
    {
        @foreach (var t in Model.Tests)
        {
                <div class="col-md-6 col-lg-4">
                <div class="card h-100 test-card">
                    <div class="card-body d-flex flex-column test-card-body">
                        <h5 class="card-title">@t.Name</h5>
                        <p class="text-muted small mb-3">@t.Description</p>
                        <div class="mt-auto d-flex gap-2">
                            <a class="btn btn-primary btn-sm flex-fill" href="@Url.Action("Take", "Tests", new { id = t.Id })">Пройти</a>
                            <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("History", "Tests", new { testId = t.Id })">История</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="text-center py-5">
                <div style="font-size:48px;">🧠</div>
                <h4 class="text-muted">Тесты не найдены</h4>
                <p class="text-muted">Пока нет доступных тестов. Психолог может создать тест в панели.</p>
            </div>
        </div>
    }
</div>

<style>
/* Ensure card bodies are full-height and actions stick to bottom */
.test-card { display: flex; flex-direction: column; height: 100%; }
.test-card-body { display: flex; flex-direction: column; }
.test-card-body .mt-auto { margin-top: auto; }
</style>

