@{
    ViewData["Title"] = "Чат";
}

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Модуль общения</p>
            <h1 class="page-title">Чат</h1>
        </div>
        <a href="#" class="btn btn-brand">Новый чат</a>
    </div>

    <div class="chat-layout">
        <aside class="chat-sidebar">
            <div class="chat-sidebar-header">
                <div>
                    <p class="section-note">Комнаты</p>
                    <h2 class="section-title">Список бесед</h2>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-ghost chat-sidebar-close d-lg-none" type="button">Закрыть</button>
                    <button class="btn btn-ghost" type="button">+</button>
                </div>
            </div>

            <div class="chat-search">
                <input type="text" class="input-field" placeholder="Поиск комнаты">
            </div>

            <div class="chat-rooms">
                <a href="#" class="chat-room-item active">
                    <div class="room-avatar">S</div>
                    <div class="room-meta">
                        <p class="room-name">Психолог</p>
                        <span class="room-preview">Ещё 3 непрочитанных сообщения</span>
                    </div>
                </a>
                <a href="#" class="chat-room-item">
                    <div class="room-avatar">G</div>
                    <div class="room-meta">
                        <p class="room-name">Группа поддержки</p>
                        <span class="room-preview">Собрание начнётся через 30 минут</span>
                    </div>
                </a>
                <a href="#" class="chat-room-item">
                    <div class="room-avatar">R</div>
                    <div class="room-meta">
                        <p class="room-name">Рекомендации</p>
                        <span class="room-preview">Последнее обновление 2 часа назад</span>
                    </div>
                </a>
            </div>
        </aside>

        <section class="chat-main">
            <div class="chat-main-header">
                <div>
                    <p class="section-note">Живой обмен</p>
                    <h2 class="thread-title">Диалог с психологом</h2>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-ghost chat-sidebar-open d-lg-none" type="button">Чаты</button>
                    <div class="thread-meta">
                        <span>Онлайн</span>
                        <span>Последнее сообщение 2 минуты назад</span>
                    </div>
                </div>
            </div>

            <div class="chat-feed" id="chatFeed">
                <div class="system-note">Сегодня</div>

            </div>

            <div class="chat-input-bar">
                <div class="chat-input-compose">
                    <textarea id="chatInput" placeholder="Напишите сообщение..." aria-label="Сообщение"></textarea>
                    <button id="chatSend" class="btn btn-brand" type="button">Отправить</button>
                </div>
                <div class="chat-actions">
                    <button class="btn btn-ghost" type="button">📎 Прикрепить</button>
                    <button class="btn btn-ghost" type="button">😊 Эмодзи</button>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.querySelector('.chat-sidebar');
            const openButton = document.querySelector('.chat-sidebar-open');
            const closeButton = document.querySelector('.chat-sidebar-close');
            const chatFeed = document.getElementById('chatFeed');
            const sendButton = document.getElementById('chatSend');
            const input = document.getElementById('chatInput');
            const room = 'general';

            if (!sidebar || !openButton || !closeButton) return;

            openButton.addEventListener('click', function () {
                sidebar.classList.add('open');
            });

            closeButton.addEventListener('click', function () {
                sidebar.classList.remove('open');
            });

            function renderMessage(message) {
                if (!chatFeed || !message) return;
                const isOutgoing = message.userName === 'Вы';
                const avatar = (message.userName || 'U').charAt(0).toUpperCase();
                const row = document.createElement('div');
                row.className = `chat-message-row ${isOutgoing ? 'outgoing' : ''}`;
                row.innerHTML = `
                    ${isOutgoing ? '' : `<div class="message-avatar">${avatar}</div>`}
                    <div class="chat-bubble ${isOutgoing ? 'chat-bubble--outgoing' : 'chat-bubble--incoming'}">
                        <div class="message-meta">
                            <span class="message-name">${message.userName || 'Пользователь'}</span>
                            <span class="message-time">${new Date(message.createdAt || Date.now()).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                        </div>
                        <p class="message-text"></p>
                    </div>`;
                row.querySelector('.message-text').textContent = message.text || '';
                chatFeed.appendChild(row);
                chatFeed.scrollTop = chatFeed.scrollHeight;
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/chatHub')
                .withAutomaticReconnect()
                .build();

            connection.on('ReceiveHistory', function (receivedRoom, history) {
                if (receivedRoom !== room || !chatFeed) return;
                chatFeed.querySelectorAll('.chat-message-row').forEach(x => x.remove());
                history.forEach(renderMessage);
            });

            connection.on('ReceiveMessage', function (receivedRoom, message) {
                if (receivedRoom === room) renderMessage(message);
            });

            connection.on('Blocked', function (message) {
                alert(message || 'Вы заблокированы в чате.');
            });

            connection.start().then(function () {
                connection.invoke('JoinRoom', room);
            });

            sendButton?.addEventListener('click', function () {
                const text = (input?.value || '').trim();
                if (!text) return;
                connection.invoke('SendMessage', room, text);
                input.value = '';
            });

            input?.addEventListener('keydown', function (event) {
                if (event.key === 'Enter' && !event.shiftKey) {
                    event.preventDefault();
                    sendButton?.click();
                }
            });
        });
    </script>
}
