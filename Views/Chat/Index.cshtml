@page
@model Sofia.Web.Views.Chat.IndexModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />

<div class="chat-page">
    <div class="chat-topbar">
        <div>
            <p class="eyebrow">Психологическая поддержка</p>
            <h1>Анонимный чат поддержки</h1>
            <p>Спокойная комната для обмена, поддержки и коротких встреч. Интерфейс вдохновлён Calm, Notion и Telegram Web.</p>
        </div>
        <button class="sidebar-toggle" type="button" aria-label="Открыть меню комнат" data-chat-toggle>
            <span class="burger"></span>
        </button>
    </div>

    <div class="chat-app" id="chatApp">
        <aside class="chat-sidebar" aria-label="Сайдбар чата">
            <div class="sidebar-header">
                <h2>Комнаты</h2>
                <span class="badge">3</span>
            </div>

            <ul class="room-list">
                <li class="room-item active" data-chat-room>
                    <div class="room-meta">
                        <strong>Группа поддержки</strong>
                        <small>Открытая комната · 12 участников</small>
                    </div>
                    <span class="room-pill">Live</span>
                </li>
                <li class="room-item" data-chat-room>
                    <div class="room-meta">
                        <strong>Тихий уголок</strong>
                        <small>Закрытая комната · 6 участников</small>
                    </div>
                </li>
                <li class="room-item" data-chat-room>
                    <div class="room-meta">
                        <strong>Вечерняя сессия</strong>
                        <small>Анонимные беседы · 8 участников</small>
                    </div>
                </li>
            </ul>

            <div class="sidebar-section">
                <div class="section-title">Онлайн сейчас</div>
                <ul class="online-list">
                    <li class="online-item">
                        <div class="status">
                            <span class="avatar">А1</span>
                        </div>
                        <div class="user-meta">
                            <strong>Аноним</strong>
                            <small>Онлайн</small>
                        </div>
                    </li>
                    <li class="online-item">
                        <div class="status">
                            <span class="avatar">Б2</span>
                        </div>
                        <div class="user-meta">
                            <strong>Другой</strong>
                            <small>Онлайн</small>
                        </div>
                    </li>
                    <li class="online-item">
                        <div class="status">
                            <span class="avatar">В3</span>
                        </div>
                        <div class="user-meta">
                            <strong>Модератор</strong>
                            <small>Может ответить</small>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="sidebar-section">
                <div class="section-title">Статус комнаты</div>
                <div class="room-labels">
                    <span class="room-label">Анонимно</span>
                    <span class="room-label">Поддержка</span>
                </div>
            </div>
        </aside>

        <div class="chat-sidebar-backdrop" data-chat-close></div>

        <section class="chat-main" aria-label="Основная область чата">
            <div class="chat-main-header">
                <div class="room-summary">
                    <h3>Группа поддержки</h3>
                    <p>Список комнат и уведомления об активности, входе и выходе. Пиши в спокойной атмосфере.</p>
                    <div class="room-labels">
                        <span class="room-label">Анонимные аватары</span>
                        <span class="room-label">Нежная поддержка</span>
                    </div>
                </div>
            </div>

            <div class="chat-window">
                <div class="chat-system-message">Система • Сегодня 09:05 · В комнате 12 участников</div>

                <div class="chat-date-marker">Сегодня</div>

                <article class="chat-message other">
                    <span class="avatar">Н</span>
                    <div class="message">
                        <p>Привет. Я только что пришёл и немного тревожусь. Как вы обычно расслабляетесь перед сном?</p>
                        <span class="meta">Аноним · 09:12</span>
                    </div>
                </article>

                <article class="chat-message self">
                    <span class="avatar">Ты</span>
                    <div class="message">
                        <p>Часто помогает глубокое дыхание и лёгкая растяжка. Главное — не форсировать, просто дышать мягко.</p>
                        <span class="meta">Ты · 09:14</span>
                    </div>
                </article>

                <article class="chat-message other">
                    <span class="avatar">П</span>
                    <div class="message">
                        <p>Спасибо, это звучит очень успокаивающе. Я попробую прямо сейчас.</p>
                        <span class="meta">Аноним · 09:15</span>
                    </div>
                </article>

                <div class="chat-system-message">Система • Алекс вошёл в комнату</div>

                <article class="chat-message other">
                    <span class="avatar">А</span>
                    <div class="message">
                        <p>Добрый день всем. Готов поддержать или просто выслушать.</p>
                        <span class="meta">Аноним · 09:18</span>
                    </div>
                </article>
            </div>

            <div class="chat-input-panel">
                <button class="icon-btn" type="button" aria-label="Прикрепить файл">📎</button>
                <input type="text" placeholder="Напишите сообщение..." aria-label="Поле ввода сообщения" />
                <button class="send-btn" type="button" aria-label="Отправить сообщение">➤</button>
            </div>
        </section>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const chatApp = document.getElementById('chatApp');
        const toggle = document.querySelector('[data-chat-toggle]');
        const closeTrigger = document.querySelector('[data-chat-close]');

        if (toggle) {
            toggle.addEventListener('click', function () {
                chatApp.classList.toggle('sidebar-open');
            });
        }

        if (closeTrigger) {
            closeTrigger.addEventListener('click', function () {
                chatApp.classList.remove('sidebar-open');
            });
        }
    });
</script>
