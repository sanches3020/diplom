@{
    var thread = ViewBag.Thread as Sofia.Web.Models.ForumThread;
    ViewData["Title"] = "Ответ в теме";
}

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Форум</p>
            <h1 class="page-title">Ответ в теме</h1>
            <div class="section-note">@(thread?.Title ?? "Тема")</div>
        </div>
    </div>

    <section class="forum-thread-panel p-4">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">Введите текст ответа.</div>
        }

        <form method="post" class="d-grid gap-3">
            <div>
                <label class="form-label">Ваш ответ</label>
                <textarea class="form-control" name="content" rows="6" maxlength="5000" required placeholder="Напишите сообщение"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Опубликовать</button>
                <a class="btn btn-outline-secondary" href="/Forum/Thread/@(thread?.Id ?? 0)">Назад к теме</a>
            </div>
        </form>
    </section>
</div>
@{
}
