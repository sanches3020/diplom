@{
    var categories = (ViewBag.Categories as IEnumerable<ForumCategory>)?.ToList() ?? new List<ForumCategory>();
    ViewData["Title"] = "Новая тема";
}

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Форум</p>
            <h1 class="page-title">Создать тему</h1>
        </div>
    </div>

    <section class="forum-thread-panel p-4">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">Проверьте заполнение формы.</div>
        }

        <form asp-action="CreateThread" asp-controller="ForumPage" method="post" class="d-grid gap-3">
            <div>
                <label class="form-label">Категория</label>
                <select class="form-select" name="categoryId" required>
                    @foreach (var category in categories)
                    {
                        <option value="@category.Id">@category.Title</option>
                    }
                </select>
            </div>

            <div>
                <label class="form-label">Заголовок</label>
                <input class="form-control" name="title" maxlength="300" required placeholder="Введите заголовок темы" />
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Создать</button>
                <a class="btn btn-outline-secondary" href="/Forum">Отмена</a>
            </div>
        </form>
    </section>
</div>
@{
}
