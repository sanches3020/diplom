@{
    ViewData["Title"] = "Профиль пользователя";
    var user = ViewBag.User as Sofia.Web.Models.ApplicationUser;
    var totalNotes = ViewBag.TotalNotes as int? ?? 0;
    var totalGoals = ViewBag.TotalGoals as int? ?? 0;
    var completedGoals = ViewBag.CompletedGoals as int? ?? 0;
    var totalEmotions = ViewBag.TotalEmotions as int? ?? 0;
}

<div class="page-section">
    <div class="page-header">
        <div>
            <p class="section-note">Пользовательский профиль</p>
            <h1 class="page-title">Настройки аккаунта</h1>
        </div>
    </div>

    <div class="settings-panel">
        <aside class="profile-card surface-panel">
            <div class="profile-preview">
                <div class="profile-preview-avatar">@((user?.FullName ?? user?.UserName ?? "П").FirstOrDefault().ToString().ToUpper())</div>
                <div class="profile-preview-info">
                    <h3>@(user?.FullName ?? user?.UserName ?? "Пользователь")</h3>
                    <p>@(user?.Email ?? "email@example.com")</p>
                </div>
            </div>
            <div class="divider"></div>
            <div class="section-note">Управляйте персональной информацией и безопасностью в одном месте.</div>
        </aside>

        <section class="settings-form surface-panel">
            <div class="settings-panel-header">
                <div>
                    <p class="section-note">Личные данные</p>
                    <h2 class="section-title">Редактирование профиля</h2>
                </div>
            </div>

            <div class="group-grid">
                <div class="field-row two-col">
                    <div>
                        <label class="form-label" for="name">Имя</label>
                        <input id="name" class="input-field" type="text" value="@(user?.FullName ?? user?.UserName ?? "")" />
                    </div>
                    <div>
                        <label class="form-label" for="email">Email</label>
                        <input id="email" class="input-field" type="email" value="@(user?.Email ?? "")" />
                    </div>
                </div>

                <div class="field-row">
                    <div>
                        <label class="form-label" for="bio">О себе</label>
                        <textarea id="bio" class="textarea-field" rows="4" placeholder="Расскажите немного о себе..."></textarea>
                        <span class="form-help">Короткая заметка для вашего профиля.</span>
                    </div>
                </div>

                <div class="field-row two-col">
                    <div>
                        <label class="form-label" for="language">Язык</label>
                        <select id="language" class="select-field">
                            <option>Русский</option>
                            <option>English</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="timezone">Часовой пояс</label>
                        <select id="timezone" class="select-field">
                            <option>UTC+3 Москва</option>
                            <option>UTC+4 Самара</option>
                            <option>UTC+5 Екатеринбург</option>
                        </select>
                    </div>
                </div>

                <div class="field-row">
                    <label class="form-label" for="password">Изменить пароль</label>
                    <input id="password" class="input-field" type="password" placeholder="Новый пароль" />
                    <span class="form-help">Оставьте пустым, если не хотите менять пароль.</span>
                </div>

                <div class="switch-control">
                    <span>Получать уведомления на email</span>
                    <input type="checkbox" checked aria-label="Email уведомления" />
                </div>

                <button class="btn btn-brand" type="button">Сохранить изменения</button>
            </div>
        </section>
    </div>
</div>
